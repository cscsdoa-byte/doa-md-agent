# /etc/systemd/system/doa-md-web.service
# Next.js production 서버를 백그라운드로 띄움. 24/7.
#
# 사용:
#   sudo systemctl daemon-reload
#   sudo systemctl enable doa-md-web
#   sudo systemctl start doa-md-web
#   sudo systemctl status doa-md-web

[Unit]
Description=Doa MD Agent — Next.js web
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/doa-md-agent/web
Environment=NODE_ENV=production
Environment=PORT=3100
# Next.js basePath 가 /md 로 빌드되어 있어야 nginx /md/ 와 매칭
ExecStart=/usr/bin/npm run start -- -p 3100
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
