# 정산자동화웹 (마진 계산용 원가/택배비/수수료 데이터 소스)
SETTLE_BASE_URL=http://3.37.214.243
# JWT Bearer 토큰. 브라우저 로그인 후 DevTools → Network 탭 → /api/* 요청의
# Request Headers → "Authorization: Bearer <토큰>" 의 토큰 부분만 복사. ~8시간 만료.
SETTLE_API_TOKEN=

# Slack (나중)
SLACK_WEBHOOK_URL=

# Notion (DB 새로 만들 예정)
NOTION_TOKEN=
NOTION_EVENTS_DB_ID=

# 크롤링 동작 모드
# headless | headed   (셀러센터 첫 로그인 시 headed 권장)
PLAYWRIGHT_MODE=headless
