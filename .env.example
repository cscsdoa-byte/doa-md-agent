# 정산자동화웹 (마진 계산용 원가/택배비/수수료 데이터 소스)
SETTLE_BASE_URL=http://3.37.214.243
# JWT Bearer 토큰. ~8시간 만료.
# 자동 갱신: SETTLE_USER + SETTLE_PASS 입력 후 `uv run python -m crawler.auto_login` 실행.
# 수동 갱신: 브라우저 로그인 → DevTools Network 탭 → /api/* 의 Authorization 헤더 토큰 복사.
SETTLE_API_TOKEN=
# 토큰 자동 갱신용 (옵션) — .env 는 gitignore 이므로 안전. 본인 PC 로컬에만 보관.
SETTLE_USER=
SETTLE_PASS=

# Slack (나중)
SLACK_WEBHOOK_URL=

# Notion (DB 새로 만들 예정)
NOTION_TOKEN=
NOTION_EVENTS_DB_ID=

# 크롤링 동작 모드
# headless | headed   (셀러센터 첫 로그인 시 headed 권장)
PLAYWRIGHT_MODE=headless
